{
  "name": "giapha-os-clone",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "start": "dotenvx run -- node .output/server/index.mjs",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --project ui-components",
    "test:server": "vitest --project server",
    "test:integration": "vitest --project integration",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:coverage": "vitest run --coverage",
    "prepare": "pnpm run githooks:init",
    "githooks:init": "husky",
    "lint": "oxlint . && oxfmt --check .",
    "lint:fix": "oxlint --fix . && oxfmt --write . && pnpm run prisma:format",
    "lint:fix:unsafe": "oxlint --fix-dangerously . && oxfmt --write . && pnpm run prisma:format",
    "lint:ci": "oxlint . && oxfmt --check .",
    "typecheck": "tsc",
    "prisma:push": "dotenvx run -- prisma db push",
    "prisma:migrate:dev": "dotenvx run -- prisma migrate dev",
    "prisma:migrate:prod": "dotenvx run -- prisma migrate deploy",
    "prisma:format": "dotenvx run -- prisma format",
    "prisma:seed": "dotenvx run -- prisma db seed",
    "prisma:studio": "dotenvx run -- prisma studio",
    "prisma:generate": "dotenvx run -- prisma generate",
    "auth:generate": "better-auth generate",
    "auth:secret": "better-auth secret"
  },
  "dependencies": {
    "@better-auth/prisma-adapter": "^1.6.1",
    "@dotenvx/dotenvx": "^1.61.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/playfair-display": "^5.2.8",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-devtools": "^0.10.2",
    "@tanstack/react-form": "^1.28.6",
    "@tanstack/react-form-devtools": "^0.2.20",
    "@tanstack/react-form-start": "^1.28.6",
    "@tanstack/react-query": "^5.96.2",
    "@tanstack/react-query-devtools": "^5.96.2",
    "@tanstack/react-router": "^1.168.10",
    "@tanstack/react-router-devtools": "^1.166.11",
    "@tanstack/react-start": "^1.167.16",
    "@tanstack/router-plugin": "^1.167.12",
    "aws4fetch": "^1.0.20",
    "better-auth": "^1.6.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "consola": "^3.4.2",
    "d3": "^7.9.0",
    "dayjs": "^1.11.20",
    "html-to-image": "^1.11.13",
    "i18next": "^26.0.4",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "lucide-react": "^1.7.0",
    "lunar-javascript": "^1.7.7",
    "nitro": "3.0.260311-beta",
    "papaparse": "^5.5.3",
    "prisma": "^7.7.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^17.0.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "unstorage": "^1.17.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@cloudflare/vite-plugin": "^1.31.1",
    "@netlify/vite-plugin-tanstack-start": "^1.3.2",
    "@playwright/test": "^1.59.1",
    "@tanstack/devtools-vite": "^0.6.0",
    "@testcontainers/postgresql": "^11.14.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/d3": "^7.4.3",
    "@types/node": "^25.5.2",
    "@types/papaparse": "^5.5.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser": "^4.1.3",
    "@vitest/browser-playwright": "^4.1.3",
    "@vitest/coverage-v8": "^4.1.3",
    "@vitest/ui": "4.0.18",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "oxlint-tsgolint": "^0.20.0",
    "pg": "^8.20.0",
    "playwright": "^1.59.1",
    "testcontainers": "^11.14.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.7",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.3",
    "vitest-browser-react": "^2.2.0",
    "wrangler": "^4.81.0"
  },
  "engines": {
    "node": "^24.0.0",
    "pnpm": "^10.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@prisma/client",
      "@prisma/engines",
      "better-sqlite3",
      "core-js",
      "cpu-features",
      "esbuild",
      "prisma",
      "protobufjs",
      "sharp",
      "ssh2",
      "workerd"
    ]
  }
}
