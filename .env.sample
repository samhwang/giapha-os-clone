# Deployment — set at BUILD time
# DEPLOYMENT_ENV=bun  # bun (default) | vercel | netlify | cloudflare

# Database
DATABASE_URL=postgresql://giapha:giapha@localhost:5432/giapha

# Auth - Generate this secret by running `bun run auth:secret`
BETTER_AUTH_SECRET=change-me-to-a-random-secret-at-least-32-chars
BETTER_AUTH_URL=http://localhost:3000

# Trusted origins (comma-delimited, optional)
# TRUSTED_ORIGINS=https://example.com,https://other.com

# Storage provider: "local" (default) or "s3"
STORAGE_PROVIDER=local

# Local file uploads (required when STORAGE_PROVIDER=local)
UPLOAD_DIR=./uploads

# S3-compatible storage (required when STORAGE_PROVIDER=s3)
# Works with AWS S3, SeaweedFS, MinIO, Cloudflare R2, Supabase Storage, etc.
# S3_ENDPOINT=http://localhost:8333
# S3_BUCKET=giapha
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=your-access-key
# S3_SECRET_ACCESS_KEY=your-secret-key
# S3_PUBLIC_URL=http://localhost:8333/giapha

# Site
SITE_NAME="Gia Phả OS"

# E2E Testing only, don't need for production
E2E_TEST_UTILS=true
